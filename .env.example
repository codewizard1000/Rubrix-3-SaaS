# Gemini API key for writing/comments/grading
API_KEY=your_gemini_api_key

# Winston API key for AI detector + plagiarism APIs
WINSTON_API_KEY=your_winston_api_key

# Supabase Auth + webhook persistence
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxx
SUPABASE_AUTH_REDIRECT_URL=https://your-domain.com/taskpane.html
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_for_webhooks_only

# Stripe checkout endpoints used by the frontend
STRIPE_CHECKOUT_ENDPOINT=/api/stripe/checkout
STRIPE_CHECKOUT_SUCCESS_URL=https://your-domain.com/taskpane.html?checkout=success
STRIPE_CHECKOUT_CANCEL_URL=https://your-domain.com/taskpane.html?checkout=cancel

# Stripe server-side secrets
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxx

# Subscription Price IDs (test mode)
STRIPE_PRICE_BASIC_MONTHLY=price_xxx
STRIPE_PRICE_BASIC_ANNUAL=price_xxx
STRIPE_PRICE_PLUS_MONTHLY=price_xxx
STRIPE_PRICE_PLUS_ANNUAL=price_xxx
STRIPE_PRICE_360_MONTHLY=price_xxx
STRIPE_PRICE_360_ANNUAL=price_xxx
STRIPE_PRICE_BASIC_HD_MONTHLY=price_xxx
STRIPE_PRICE_BASIC_HD_ANNUAL=price_xxx
STRIPE_PRICE_PLUS_HD_MONTHLY=price_xxx
STRIPE_PRICE_PLUS_HD_ANNUAL=price_xxx
STRIPE_PRICE_360_HD_MONTHLY=price_xxx
STRIPE_PRICE_360_HD_ANNUAL=price_xxx

# Top-up Price IDs (50,000 words each)
STRIPE_PRICE_TOPUP_CORE=price_xxx
STRIPE_PRICE_TOPUP_AI_DETECTION=price_xxx
STRIPE_PRICE_TOPUP_PLAGIARISM=price_xxx

# Optional direct checkout URL fallbacks (if checkout endpoint unavailable)
STRIPE_BASIC_MONTHLY_CHECKOUT_URL=
STRIPE_BASIC_ANNUAL_CHECKOUT_URL=
STRIPE_PLUS_MONTHLY_CHECKOUT_URL=
STRIPE_PLUS_ANNUAL_CHECKOUT_URL=
STRIPE_PLAN_360_MONTHLY_CHECKOUT_URL=
STRIPE_PLAN_360_ANNUAL_CHECKOUT_URL=
